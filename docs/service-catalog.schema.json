{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-chain.local/schemas/service-catalog.schema.json",
  "title": "Agent Commerce Service Catalog",
  "type": "object",
  "required": ["merchant", "services"],
  "properties": {
    "merchant": {
      "type": "object",
      "required": ["name", "domain"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 },
        "support_uri": { "type": "string" },
        "terms_uri": { "type": "string" },
        "privacy_uri": { "type": "string" }
      },
      "additionalProperties": true
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["service_id", "endpoint", "method", "capability", "payment", "io"],
        "properties": {
          "service_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "endpoint": { "type": "string", "format": "uri" },
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "capability": {
            "type": "object",
            "required": ["hash", "tags"],
            "properties": {
              "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
              "tags": { "type": "array", "items": { "type": "string" } }
            }
          },
          "payment": {
            "type": "object",
            "required": ["scheme", "network", "token", "amount"],
            "properties": {
              "scheme": { "type": "string", "enum": ["transfer", "swap", "facilitator", "x402"] },
              "network": { "type": "string", "minLength": 1 },
              "token": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
              "amount": { "type": "string", "pattern": "^[0-9]+$" },
              "target": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
              "swap_router": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
              "facilitator": {
                "type": "object",
                "required": ["address", "url"],
                "properties": {
                  "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
                  "url": { "type": "string", "format": "uri" }
                }
              }
            }
          },
          "io": {
            "type": "object",
            "required": ["input_schema", "output_schema"],
            "properties": {
              "input_schema": { "type": "object" },
              "output_schema": { "type": "object" }
            }
          },
          "sla": {
            "type": "object",
            "properties": {
              "timeout_ms": { "type": "integer", "minimum": 1 },
              "availability_target": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "refund": {
            "type": "object",
            "properties": {
              "policy_uri": { "type": "string" },
              "automatic_if_timeout": { "type": "boolean" },
              "dispute_window_seconds": { "type": "integer", "minimum": 0 }
            }
          },
          "privacy": {
            "type": "object",
            "properties": {
              "stores_request": { "type": "boolean" },
              "stores_response": { "type": "boolean" },
              "pii_allowed": { "type": "boolean" },
              "redaction_required": { "type": "boolean" }
            }
          },
          "required_attestations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["schema"],
              "properties": {
                "schema": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
                "subject": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
              }
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
